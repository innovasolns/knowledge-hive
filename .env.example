# Optional: Gemini API for AI features
# GEMINI_API_KEY=your_gemini_api_key

# Community access: add your $5 payment link (Stripe, Lemon Squeezy, etc.)
# NEXT_PUBLIC_COMMUNITY_PAYMENT_URL=https://buy.stripe.com/... or your payment page URL

# Optional: override the GHL community learning URL
# NEXT_PUBLIC_COMMUNITY_LEARNING_URL=https://learn.streamlinestudio.net/communities/groups/knowledge-hive/learning

# Optional: use images from your GHL community. Right‑click an image on the community page → Copy image address, then set below.
# NEXT_PUBLIC_IMAGE_HERO=https://learn.streamlinestudio.net/...
# NEXT_PUBLIC_IMAGE_PROFILE1=...
# NEXT_PUBLIC_IMAGE_DATANODES=...
# NEXT_PUBLIC_IMAGE_AVATAR1=...
# NEXT_PUBLIC_IMAGE_AVATAR2=...
# NEXT_PUBLIC_IMAGE_AVATAR3=...
# NEXT_PUBLIC_IMAGE_USER_AVATAR=...
# NEXT_PUBLIC_IMAGE_COURSE1=... through NEXT_PUBLIC_IMAGE_COURSE6=...
